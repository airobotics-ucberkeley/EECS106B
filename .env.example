# Copy to ".env" and fill in your tokens. Loaded by the helpers and by
# scripts/setup_racing_drone_assets.py via huggingface_hub's auto-detection.
# Never commit your real .env.

# --- Weights & Biases ---
# https://wandb.ai/authorize
WANDB_API_KEY=

# Optional: choose a wandb mode.
# online   - log to wandb.ai
# offline  - log locally only (sync later with `wandb sync`)
# disabled - no logging at all
# WANDB_MODE=online

# --- Hugging Face ---
# https://huggingface.co/settings/tokens (read scope is sufficient)
# Used by scripts/setup_racing_drone_assets.py to download the 5-inch racing
# drone's heavy assets (the public dataset
# https://huggingface.co/datasets/ckwolfe/eecs106b-racing-drone-assets does
# not require a token, but supplying one avoids hf-hub rate limits).
HF_TOKEN=
